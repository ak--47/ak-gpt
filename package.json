{
	"name": "@ak--47/ak-gpt",
	"author": "ak@mixpanel.com",
	"description": "AK's OpenAI GPT Helper for doing... everything",
	"version": "0.0.11",
	"main": "index.js",
	"files": [
		"index.js",
		"index.cjs",
		"base.js",
		"transformer.js",
		"chat.js",
		"message.js",
		"tool-agent.js",
		"code-agent.js",
		"rag-agent.js",
		"json-helpers.js",
		"types.d.ts",
		"logger.js",
		"GUIDE.md"
	],
	"types": "types.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./types.d.ts",
				"default": "./index.js"
			},
			"require": {
				"types": "./types.d.ts",
				"default": "./index.cjs"
			}
		}
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ak--47/ak-gpt"
	},
	"bugs": {
		"url": "https://github.com/ak--47/ak-gpt/issues"
	},
	"homepage": "https://github.com/ak--47/ak-gpt#readme",
	"scripts": {
		"prepublishOnly": "npm run typecheck && npm run build:cjs",
		"post": "npm publish",
		"release": "npm version patch && npm publish --access public",
		"update-deps": "npx npm-check-updates -u && npm install",
		"prune": "rm -rf tmp/*",
		"test": "node --no-warnings --experimental-vm-modules node_modules/jest/bin/jest.js",
		"build:cjs": "esbuild index.js --bundle --platform=node --format=cjs --outfile=index.cjs --external:openai --external:dotenv --external:pino-pretty --external:pino",
		"coverage": "node --no-warnings --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
		"typecheck": "tsc --noEmit"
	},
	"type": "module",
	"keywords": [
		"openai",
		"gpt",
		"ai wrapper",
		"json transform",
		"chat",
		"agent",
		"tool agent"
	],
	"license": "ISC",
	"dependencies": {
		"openai": "^5.0.0",
		"dotenv": "^17.3.1",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3"
	},
	"devDependencies": {
		"@types/jest": "^30.0.0",
		"esbuild": "^0.27.4",
		"jest": "^30.3.0",
		"typescript": "^5.9.3"
	}
}
